# TinyFish (https://tinyfish.ai — web scanning + agent intelligence)
# Get key: https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=

# Redis Cloud (https://redis.io/try-free — official Redis sponsor, free 30MB)
# Get connection string from: Redis Cloud console → Connect → redis-cli → copy URL
REDIS_URL=redis://default:<password>@<host>:<port>

# WunderGraph Cosmo (https://wundergraph.com — optional, API federation)
WUNDERGRAPH_API_URL=
WUNDERGRAPH_API_KEY=
